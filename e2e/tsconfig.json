{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "rootDir": "..",
    "outDir": "dist"
  },
  "include": [
    "*.ts",
    "lib/**/*.ts",
    "../clients/ts/**/*.ts"
  ]
}
